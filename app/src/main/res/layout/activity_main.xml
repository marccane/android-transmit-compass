<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:padding="16dp">

    <!-- Compass graphic -->
    <com.example.compass.CompassView
        android:id="@+id/compassView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toTopOf="@id/ipRow"
        app:layout_constraintVertical_bias="0.0" />

    <!-- IP row -->
    <LinearLayout
        android:id="@+id/ipRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/compassView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP:"
            android:textColor="#AAAACC"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />

        <EditText
            android:id="@+id/ipEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:hint="192.168.1.100"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:textSize="16sp"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Port:"
            android:textColor="#AAAACC"
            android:textSize="14sp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp" />

        <EditText
            android:id="@+id/portEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="5000"
            android:text="5000"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:textSize="16sp"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Send toggle button -->
    <Button
        android:id="@+id/sendToggleButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:text="@string/start_sending"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="@color/start_color"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/ipRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/idle"
        android:textColor="#7788AA"
        android:textSize="13sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/sendToggleButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
